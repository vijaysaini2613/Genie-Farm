{
  "name": "customer-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 4000",
    "build": "node scripts/build.js",
    "vercel-build": "node scripts/build.js",
    "deploy": "npx wrangler pages deploy .vercel/output/static --project-name geniefarm-customers",
    "start": "next start -p 4000",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.14.2",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "@cloudflare/next-on-pages": {
      "next": "$next",
      "vercel": "$vercel"
    }
  }
}
